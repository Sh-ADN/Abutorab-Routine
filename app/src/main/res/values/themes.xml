<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MyApplication" parent="android:Theme.DeviceDefault.NoActionBar" />

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set the splash screen background -->
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <!-- Use windowSplashScreenAnimatedIcon to add a drawable or an animated drawable. -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/school_logo_large</item>
        <!-- Set the post splash screen theme -->
        <item name="postSplashScreenTheme">@style/Theme.MyApplication</item>
    </style>
</resources>
